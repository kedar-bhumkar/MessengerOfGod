# ─── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── Scheduler ────────────────────────────────────────────────────────────────
# Cron expression for how often to check for due contacts
# Every 30 minutes (production):  */30 * * * *
# Every 2 minutes  (development): */2 * * * *
SCHEDULER_CRON=*/30 * * * *

# Earliest and latest hour (24h, local to each contact's timezone) to send messages
SEND_WINDOW_START=8
SEND_WINDOW_END=21

# ─── Server ───────────────────────────────────────────────────────────────────
WEBHOOK_PORT=3000

# ─── WhatsApp session ─────────────────────────────────────────────────────────
# Directory where Baileys persists the WhatsApp Web session.
# This folder is gitignored — never commit its contents.
WHATSAPP_SESSION_DIR=./whatsapp-session
