dist/

# ─── Environment / secrets ────────────────────────────────────────────────────
# NEVER commit these — they contain API keys and credentials
.env
Tools.md
.env.local
.env.*.local
.env.production
.env.staging

# ─── WhatsApp session (SENSITIVE) ─────────────────────────────────────────────
# Contains your WhatsApp authentication credentials and Signal protocol keys.
# Committing this would allow anyone to impersonate your WhatsApp account.
whatsapp-session/

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ─── OS cruft ─────────────────────────────────────────────────────────────────
